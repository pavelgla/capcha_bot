# ─── Обязательные переменные ─────────────────────────────────────────────────

# Токен бота от @BotFather
# Пример: 123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_TOKEN=

# ID чата, в котором бот будет проверять новых участников.
# Для группы/супергруппы — отрицательное число: -1001234567890
# Узнать: переслать сообщение из чата боту @userinfobot
CHAT_ID=

# ─── Опциональные переменные ──────────────────────────────────────────────────

# ID администраторов через запятую (могут использовать /unmute, /mutestat, /banned)
# Пример: 123456789,987654321
# Если не указано — только администраторы Telegram-чата
ADMIN_IDS=

# Таймаут капчи в секундах (по умолчанию 300 = 5 минут)
CAPTCHA_TIMEOUT=300

# Количество попыток ответить на капчу (по умолчанию 2)
CAPTCHA_ATTEMPTS=2

# URL подключения к Redis.
# В Docker Compose имя сервиса "redis" резолвится автоматически.
REDIS_URL=redis://redis:6379

# ─── Веб-панель ───────────────────────────────────────────────────────────────

# Секретный ключ для подписи cookie-сессий. Обязательно измените!
WEB_SECRET_KEY=changeme

# Суперадмин-аккаунт для первого запуска.
# После создания аккаунта в Redis эти переменные НЕ обновляют пароль повторно.
# Смена пароля — через веб-панель в Личном кабинете.
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=changeme-admin
